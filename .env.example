# Node.js 执行路径
# 在终端运行 `which node` 命令获取
NODE_PATH=/usr/local/bin/node

# Upload 快捷键
# Format: modifiers+key (e.g. cmd+alt+X)
# Default: cmd+alt+X
UPLOAD_SHORTCUT=cmd+alt+X

# 临时文件存储路径
# 用于保存截图等生成的临时文件
# Default: /tmp/
TMPDIR=/tmp/

# 上传配置
# 是否使用HTTPS (默认 true)
UPLOAD_HTTPS=true

# 开启压缩 (默认 true)
UPLOAD_MIN=true

# 是否忽略错误 (默认 false)
UPLOAD_FORCE=false

# 图片压缩快捷键
# Format: modifiers+key (e.g. cmd+alt+M)
# Default: cmd+alt+M
COMPRESS_SHORTCUT=cmd+alt+M

# 压缩质量 (1-100, 默认 80)
# 数值越低压缩率越高，但画质损失越大
COMPRESS_QUALITY=80

# Chrome 快捷键
# Format: modifiers+key (e.g. alt+space)
# Default: alt+space
CHROME_SHORTCUT=alt+space

# Chrome 应用路径（用于启动应用）
# Default: /Applications/Google Chrome.app
CHROME_APP=/Applications/Google Chrome.app

# Chrome bundleID（用于查找运行中的应用）
# Default: com.google.Chrome
CHROME_BUNDLE=com.google.Chrome

# 剪贴板多行合并快捷键
# Format: modifiers+key (e.g. cmd+alt+O)
# Default: cmd+alt+O
MERGE_LINES_SHORTCUT=cmd+alt+O

# cmux 快捷键
# Format: modifiers+key (e.g. cmd+alt+E)
# Default: cmd+alt+E
CMUX_SHORTCUT=cmd+alt+E

# cmux 应用路径（用于启动应用）
# Default: /Applications/cmux.app
CMUX_APP=/Applications/cmux.app

# cmux bundleID（用于查找运行中的应用）
# Default: com.cmuxterm.app
CMUX_BUNDLE=com.cmuxterm.app
