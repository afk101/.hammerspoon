# Node.js 执行路径
# 在终端运行 `which node` 命令获取
NODE_PATH=/usr/local/bin/node

# Upload 快捷键
# Format: modifiers+key (e.g. cmd+alt+X)
# Default: cmd+alt+X
UPLOAD_SHORTCUT=cmd+alt+X

# 临时文件存储路径
# 用于保存截图等生成的临时文件
# Default: /tmp/
TMPDIR=/tmp/

# 上传配置
# 是否使用HTTPS (默认 true)
UPLOAD_HTTPS=true

# 开启压缩 (默认 true)
UPLOAD_MIN=true

# 是否忽略错误 (默认 false)
UPLOAD_FORCE=false

# 图片压缩快捷键
# Format: modifiers+key (e.g. cmd+alt+C)
# Default: cmd+alt+C
COMPRESS_SHORTCUT=cmd+alt+C

# 压缩质量 (1-100, 默认 80)
# 数值越低压缩率越高，但画质损失越大
COMPRESS_QUALITY=80

# 豆包浏览器快捷键
# Format: modifiers+key (e.g. alt+space)
# Default: alt+space
DOUBAO_BROWSER_SHORTCUT=alt+space

# 豆包浏览器应用路径（用于启动应用）
# Default: /Applications/Doubao.app/Contents/Helpers/Doubao Browser.app
DOUBAO_BROWSER_APP=/Applications/Doubao.app/Contents/Helpers/Doubao Browser.app

# 豆包浏览器 bundleID（用于查找运行中的应用）
# Default: com.bot.pc.doubao.browser
DOUBAO_BROWSER_BUNDLE=com.bot.pc.doubao.browser
